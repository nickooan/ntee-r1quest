{
  "name": "ntee-r1quest",
  "version": "0.7.0",
  "homepage": "https://codeberg.org/nickoan/ntee-r1quest",
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "bin": {
    "ntee-r1quest": "./dist/index.js",
    "r1q": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/assets",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node ./bin/scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node ./bin/scripts/copy-grammar-assets.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "start:codex": "node ./dist/index.js -r ./example -ai codex",
    "start:claude": "node ./dist/index.js -r ./example -ai claude",
    "start": "node ./dist/index.js -r ./example",
    "start:p": "node ./dist/index.js -r ./example -p request/example",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "typecheck": "tsc -p tsconfig.json",
    "pack:dry-run": "npm run build && npm pack --dry-run",
    "clean": "node ./bin/scripts/clean-dist.mjs",
    "version:bump": "node ./bin/scripts/bump-version.mjs"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "jest": "^30.2.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.36.1",
    "@agentclientprotocol/sdk": "^0.22.1",
    "@types/react": "^19.2.14",
    "@zed-industries/codex-acp": "^0.14.0",
    "axios": "^1.16.1",
    "ink": "^7.0.1",
    "ohm-js": "^17.5.0",
    "react": "^19.2.5"
  }
}
