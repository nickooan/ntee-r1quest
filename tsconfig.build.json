{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["dist", "test", "**/*.test.ts", "**/*.test.tsx"]
}
